# EditorConfig for CFS - Industry Standards
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.{md,yml,yaml,json}]
indent_size = 2

[*.go]
indent_size = 4

[Makefile]
indent_style = tab

# Database migrations
[*.sql]
indent_size = 2

# Scripts
[*.sh]
indent_size = 2
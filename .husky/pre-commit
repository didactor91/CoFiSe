#!/bin/sh
# CFS Pre-commit Hook

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Branch name checks (prevent committing to main/master directly)
BRANCH_NAME=$(git symbolic-ref --short HEAD 2>/dev/null)
if [ "$BRANCH_NAME" = "main" ] || [ "$BRANCH_NAME" = "master" ]; then
  echo "${RED}✖ Cannot commit directly to $BRANCH_NAME branch${NC}"
  echo "   Please create a feature branch and open a PR"
  exit 1
fi

echo "${GREEN}✓ Running pre-commit checks...${NC}"

# Get staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
if [ -z "$STAGED_FILES" ]; then
  echo "No staged files to lint"
  exit 0
fi

# Run lint-staged if available
if [ -f "cfs/node_modules/lint-staged/package.json" ]; then
  echo "${GREEN}✓ Running lint-staged...${NC}"
  cd cfs && npx lint-staged
else
  echo "${YELLOW}⚠ lint-staged not found, running basic ESLint and Prettier checks...${NC}"
  
  if [ -f "cfs/node_modules/eslint/package.json" ]; then
    echo "Running ESLint..."
    cd cfs && npx eslint --max-warnings=0 .
  fi
  
  if [ -f "cfs/node_modules/prettier/package.json" ]; then
    echo "Checking Prettier formatting..."
    cd cfs && npx prettier --check .
  fi
fi

echo "${GREEN}✓ Pre-commit checks passed${NC}"
